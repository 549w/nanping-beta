# ============================================================
# Nanping 环境变量模板
# 复制为 backend/.env 并填入实际值
# ============================================================

# ---- 数据库 ----
# 开发环境（SQLite 本地文件，无需安装任何数据库服务）
# DATABASE_URL=sqlite+aiosqlite:///data/nanping.db
# 生产环境（PostgreSQL，由 docker-compose 自动创建和管理）
DATABASE_URL=postgresql+asyncpg://nanping:nanping@db:5432/nanping

# ---- JWT ----
# 生产环境务必更换为随机长字符串
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- CORS ----
# 允许的跨域来源，逗号分隔的域名列表，或 * 表示允许所有
# 注意：allow_origins=["*"] 时 allow_credentials 必须为 False
CORS_ORIGINS=*

# ---- 认证 Mock 模式 ----
# 开发阶段设为 true，跳过真实邮件发送，使用固定验证码
AUTH_MOCK_MODE=true
MOCK_VERIFICATION_CODE=123456

# ---- SMTP（仅 AUTH_MOCK_MODE=false 时需要） ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ---- 教务系统 cookies（仅爬取脚本使用） ----
OFFICIAL_COOKIES=

# ---- LLM API（AI 评分脚本使用） ----
# 支持所有 OpenAI 兼容的 API（OpenAI / DeepSeek / Qwen / 智谱 / Ollama 等）
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_DELAY_SECONDS=0.5
LLM_MAX_RETRIES=3
