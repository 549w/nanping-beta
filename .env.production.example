# ============================================================
# Nanping 生产环境变量
# 部署时复制此文件到服务器 /opt/nanping/.env.production
# 填入实际值后 chmod 600 保护敏感信息
# ============================================================

# ---- 数据库 ----
# 使用容器内绝对路径（四个斜杠），对应卷挂载的 /app/data/
DATABASE_URL=sqlite+aiosqlite:////app/data/nanping.db

# ---- JWT 认证 ----
# 生产环境务必替换为随机密钥：python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- CORS ----
# 限定允许跨域的前端来源
CORS_ORIGINS=["https://nanping.eznju.com"]

# ---- 认证模式 ----
# 生产环境设为 false，使用真实 SMTP 发送邮件
AUTH_MOCK_MODE=false
MOCK_VERIFICATION_CODE=

# ---- Resend 邮件服务 ----
# 1. 注册 https://resend.com
# 2. 在 Domains 中添加 eznju.com 并验证 DNS 记录
# 3. 在 API Keys 中创建密钥：https://resend.com/api-keys
RESEND_API_KEY=
SENDER_EMAIL=noreply@eznju.com
